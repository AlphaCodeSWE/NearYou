# Ambiente di sviluppo - Configurazione di default per NearYou
# Questi valori sono preconfigurati per funzionare con docker-compose.dev.yml

# === Configurazione Generale ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# === Kafka Configuration ===
KAFKA_BROKER=kafka:9093
KAFKA_TOPIC=gps_stream
CONSUMER_GROUP=gps_consumers_group
KAFKA_KEYSTORE_PASS=developmentpass123

# === Database Configuration ===
# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=development
CLICKHOUSE_DATABASE=nearyou

# PostgreSQL/PostGIS
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nearyou
POSTGRES_PASSWORD=development
POSTGRES_DB=nearyou_shops

# === Redis Cache ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=development
CACHE_TTL=3600
CACHE_ENABLED=true

# === Security Configuration ===
JWT_SECRET=development-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_S=3600

# === SSL Configuration (development) ===
SSL_CAFILE=/workspace/certs/ca.crt
SSL_CERTFILE=/workspace/certs/client_cert.pem
SSL_KEYFILE=/workspace/certs/client_key.pem

# === OSRM Configuration ===
OSRM_URL=http://osrm:5000
MILANO_MIN_LAT=45.35
MILANO_MAX_LAT=45.55
MILANO_MIN_LON=9.05
MILANO_MAX_LON=9.35
PBF_URL=https://download.geofabrik.de/europe/italy/nord-ovest-latest.osm.pbf

# === LLM Configuration ===
LLM_PROVIDER=groq
OPENAI_API_KEY=your-development-api-key-here
OPENAI_API_BASE=https://api.groq.com/openai/v1

# === Service URLs ===
MESSAGE_GENERATOR_URL=http://message-generator:8001/generate
API_GATEWAY_URL=http://api-gateway:8000
DASHBOARD_URL=http://dashboard:8003

# === Development Tools ===
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
GRAFANA_ADMIN_USERNAME=admin
GRAFANA_ADMIN_PASSWORD=admin